# FitSense AI Dashboard - Environment Variables
# Copy this file to .env and fill in your values
#
# SECURITY NOTE: This dashboard is configured for READ-ONLY access.
# All queries are validated to ensure only SELECT statements are executed.
# Write operations (INSERT, UPDATE, DELETE, DROP, etc.) are blocked at the
# application level for data protection.
#
# RECOMMENDED: For production, create a read-only MySQL user:
#   CREATE USER 'fitsense_readonly'@'localhost' IDENTIFIED BY 'strong_password';
#   GRANT SELECT ON fitsense_ai.* TO 'fitsense_readonly'@'localhost';
#   FLUSH PRIVILEGES;

# MySQL Connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=fitsense_ai

# Google OAuth (optional - for authentication)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
